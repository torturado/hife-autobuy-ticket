# ============================================
# CONFIGURACIÓN DE TELEGRAM
# ============================================
# Token del bot de Telegram (obtener de @BotFather)
TELEGRAM_TOKEN=your_telegram_bot_token_here

# ID de usuario de Telegram (obtener de @userinfobot)
TELEGRAM_USER_ID=your_telegram_user_id_here

# ============================================
# CONFIGURACIÓN DE HIFE API
# ============================================
# URL base de la API de HIFE (normalmente no cambiar)
HIFE_API_URL=https://middleware.hife.es/api

# Token JWT de autenticación (obtener del setup_wizard.py o de los logs de la app móvil)
# Formato: Bearer eyJ0eXAiOiJKV1Qi...
HIFE_AUTH_TOKEN=Bearer your_jwt_token_here

# Client ID de HIFE (normalmente 33798)
HIFE_CLIENT_ID=33798

# Versión de la app (normalmente 2.0.8)
HIFE_APP_VERSION=2.0.8

# ============================================
# CONFIGURACIÓN DE ESTACIONES
# ============================================
# ID numérico de la estación de origen (sin ceros iniciales, ej: 15 para 0015)
ORIGIN_ID=

# Código de parada de origen (con ceros iniciales, ej: 0015)
ORIGIN_STOP_CODE=

# ID numérico de la estación de destino (sin ceros iniciales, ej: 3 para 0003)
DESTINATION_ID=

# Código de parada de destino (con ceros iniciales, ej: 0003)
DESTINATION_STOP_CODE=

# ============================================
# CONFIGURACIÓN DE BONO
# ============================================
# ID del bono a utilizar (19 = MITMA Joven, pero puede variar)
BONUS_ID=19

# ============================================
# HORARIOS DE IDA
# ============================================
# Hora por defecto para ida (formato HH:MM)
OUTWARD_TIME_DEFAULT=06:45

# Horarios específicos por día (dejar vacío para usar el default)
OUTWARD_TIME_MONDAY=
OUTWARD_TIME_TUESDAY=
OUTWARD_TIME_WEDNESDAY=
OUTWARD_TIME_THURSDAY=
OUTWARD_TIME_FRIDAY=

# ============================================
# HORARIOS DE VUELTA
# ============================================
# Hora por defecto para vuelta (formato HH:MM)
RETURN_TIME_DEFAULT=14:45

# Horarios específicos por día (dejar vacío para usar el default)
RETURN_TIME_MONDAY=
RETURN_TIME_TUESDAY=
RETURN_TIME_WEDNESDAY=
RETURN_TIME_THURSDAY=
RETURN_TIME_FRIDAY=

# ============================================
# CONFIGURACIÓN DE NOTIFICACIONES
# ============================================
# Minutos de antelación para notificar antes del viaje (default: 120 = 2 horas)
NOTIFICATION_ADVANCE_MINUTES=120

# Intervalo en minutos para revisar horarios (default: 10)
CHECK_INTERVAL_MINUTES=10
